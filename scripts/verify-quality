#!/usr/bin/env bash
# verify-quality - Aggregates existing reports from cmake-skill and cpp-lint
# This script does NOT execute other skills. It only reads report files.
set -euo pipefail

PROJECT_ROOT="${1:-.}"
cd "$PROJECT_ROOT"

QUALITY_DIR="quality_reports"
mkdir -p "$QUALITY_DIR"

HAS_DATA=0
CMK_JSON=""
CMK_MD=""

# --- Discover cmake-skill reports via manifest ---
echo "=== Discovering cmake-skill reports ==="
if [ -f ".cmake-skill-manifest.json" ]; then
    echo "  Found manifest: .cmake-skill-manifest.json"
    CMK_JSON=$(python3 -c "import json,sys; m=json.load(open('.cmake-skill-manifest.json')); print(m.get('json_report',''))")
    CMK_MD=$(python3 -c "import json,sys; m=json.load(open('.cmake-skill-manifest.json')); print(m.get('md_report',''))")
    echo "  json_report: $CMK_JSON"
    echo "  md_report: $CMK_MD"
else
    echo "  No manifest found, searching common locations..."
    # Search common output directories
    for dir in cmake_reports build/*/cmake_reports; do
        if [ -f "$dir/cmake_report.json" ]; then
            CMK_JSON="$dir/cmake_report.json"
            CMK_MD="$dir/cmake_report.md"
            echo "  Found: $dir"
            break
        fi
    done
fi

# --- Copy cmake-skill reports ---
if [ -n "$CMK_JSON" ] && [ -f "$CMK_JSON" ]; then
    cp -f "$CMK_JSON" "$QUALITY_DIR/cmake_report.json"
    echo "  Copied: $CMK_JSON"
    HAS_DATA=1
else
    echo "  Missing: cmake_report.json"
fi

if [ -n "$CMK_MD" ] && [ -f "$CMK_MD" ]; then
    cp -f "$CMK_MD" "$QUALITY_DIR/cmake_report.md"
    echo "  Copied: $CMK_MD"
fi

# --- Discover cpp-lint reports ---
echo "=== Discovering cpp-lint reports ==="
CPP_REPORTS="cpp_lint_reports"
if [ -f "$CPP_REPORTS/lint_report.json" ]; then
    cp -f "$CPP_REPORTS/lint_report.json" "$QUALITY_DIR/"
    echo "  Copied: $CPP_REPORTS/lint_report.json"
    HAS_DATA=1
else
    echo "  Missing: $CPP_REPORTS/lint_report.json"
fi

if [ -f "$CPP_REPORTS/lint_report.md" ]; then
    cp -f "$CPP_REPORTS/lint_report.md" "$QUALITY_DIR/"
    echo "  Copied: $CPP_REPORTS/lint_report.md"
fi

# --- Generate consolidated report ---
{
    echo "# Quality Gate Report"
    echo ""
    echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo ""

    if [ -f "$QUALITY_DIR/cmake_report.md" ]; then
        echo "## CMake Build & Lint"
        echo ""
        cat "$QUALITY_DIR/cmake_report.md"
        echo ""
    fi

    if [ -f "$QUALITY_DIR/lint_report.md" ]; then
        echo "## C++ Lint & Format"
        echo ""
        cat "$QUALITY_DIR/lint_report.md"
    fi

    if [ $HAS_DATA -eq 0 ]; then
        echo "## No Report Data Found"
        echo ""
        echo "Run cmake-skill and cpp-lint first to generate reports:"
        echo "  - cmake-skill pipeline --preset <preset>"
        echo "  - cpp-lint changed"
    fi
} > "$QUALITY_DIR/quality_gate_report.md"

echo ""
echo "=== Report saved to $QUALITY_DIR/quality_gate_report.md ==="

[ $HAS_DATA -eq 0 ] && exit 1
exit 0
